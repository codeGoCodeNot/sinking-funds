generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Fund {
  id            String     @id @default(uuid())
  name          String
  description   String?
  months        Int        @default(12)
  monthlyAmount Float
  saved         Float      @default(0)
  interest      Float      @default(0)
  status        FundStatus @default(in_progress)
  dueDay        Int        @default(1)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  payments      Payment[]
}

enum FundStatus {
  in_progress
  completed
  inactive
}

model Payment {
  id        String   @id @default(uuid())
  fundId    String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)
}
